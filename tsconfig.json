{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "paths": {
      "$state/*":      ["./src/state/*"],
      "$components/*": ["./src/components/*"],
      "$data/*":       ["./src/data/*"],
      "$utils/*":      ["./src/utils/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"]
}